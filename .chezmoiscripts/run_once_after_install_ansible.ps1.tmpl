{{- if eq .chezmoi.os "windows" -}}
# vim: ft=ps1 :

if (-not (Get-Command ansible -ErrorAction SilentlyContinue)) {
    Write-Host "Ansible was not found." -ForegroundColor Cyan
    Write-Host "Installing via pip..." -ForegroundColor Cyan

    # Ensure Python/Pip is available first
    python -m pip install --user ansible
    ansible-galaxy collection install community.general

if (-not (ansible-galaxy collection list | Select-String "community" -Quiet)) {
    Write-Host "Installing community.general package for Ansible."
    ansible-galaxy collection install community.general
}

& ansible-playbook "{{ .chezmoi.destDir }}/.bootstrap/ansible.yaml" --ask-become-pass | Out-Host

Write-Host "If you ever want to re-run the Ansible playbook, execute 'dotfiles-install' on your shell."
{{- end }}
