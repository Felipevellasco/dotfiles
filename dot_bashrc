#!/usr/bin/env bash
# vim: set filetype=bash :

# Start profiling
__profile_start=$(date +%s%3N)

# --- Common environment --- #
source "$HOME/.config/shell/environment"

HISTFILE="$BASH_HISTFILE"

# --- Splash screen --- #

splash="$HOME/.config/shell/splash"
splash_txt=$(mktemp -p /dev/shm/ splash.XXXXXXXXXX)
trap 'rm -f "$splash_txt"' EXIT INT TERM ERR
pid_splash=""

if [ "$SHLVL" -eq 1 ]; then
    splash="$HOME/.config/shell/splash"
    splash_txt=$(mktemp -p /dev/shm/ splash.XXXXXXXXXX)
    trap 'rm -f "$splash_txt"' EXIT INT TERM ERR

    source "$splash" > "$splash_txt" 2>/dev/null &
    pid_splash=$!
fi

# --- Starship --- #
eval "$(starship init bash)"

# --- Activation --- #

# Enables command autocompletion
[ -f /etc/bash_completion ] && . /etc/bash_completion
[ -f /usr/share/bash-completion/bash_completion ] && . /usr/share/bash-completion/bash_completion

eval "$(zoxide init bash)"
eval "$(fzf --bash)"
eval "$(direnv hook bash)"

# Load aliases
source "$HOME/.config/shell/alias"

# --- Print splash screen to the terminal --- #

if [[ -n $pid_splash ]]; then
    wait "$pid_splash" 2>/dev/null

    /bin/cat "$splash_txt"
fi

# End profiling
__profile_end=$(date +%s%3N)
__profile_elapsed=$((__profile_end - __profile_start))
echo "Profile loaded in ${__profile_elapsed} ms."
